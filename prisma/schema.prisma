// ============================================================
// MÓDULO R — Indicadores (3 níveis) + leituras mensais
// ============================================================
model Indicator {
  id             String             @id @default(uuid()) @db.Uuid
  organizationId String             @map("organization_id") @db.Uuid
  level          IndicatorLevel     @default(area)
  areaId         String?            @map("area_id") @db.Uuid
  teamId         String?            @map("team_id") @db.Uuid
  ownerUserId    String?            @map("owner_user_id") @db.Uuid
  name           String
  description    String?
  unit           String? // %, R$, un, dias, etc.
  direction      IndicatorDirection @default(higher_better)
  target         Float?
  minTarget      Float?             @map("min_target")
  maxTarget      Float?             @map("max_target")
  tags           String[]           @default([])
  active         Boolean            @default(true)
  csvSyncUrl     String?            @map("csv_sync_url")
  lastSyncAt     DateTime?          @map("last_sync_at")
  createdBy      String?            @map("created_by") @db.Uuid
  updatedBy      String?            @map("updated_by") @db.Uuid
  createdAt      DateTime           @default(now()) @map("created_at")
  updatedAt      DateTime           @updatedAt @map("updated_at")

  readings IndicatorReading[]

  @@index([organizationId])
  @@index([level])
  @@index([areaId])
  @@index([teamId])
  @@map("indicators")
}

model IndicatorReading {
  id          String                 @id @default(uuid()) @db.Uuid
  indicatorId String                 @map("indicator_id") @db.Uuid
  periodYear  Int                    @map("period_year")
  periodMonth Int                    @map("period_month") // 1-12
  value       Float
  notes       String?
  plan        String?                @map("pdca_plan")
  doAction    String?                @map("pdca_do")
  check       String?                @map("pdca_check")
  act         String?                @map("pdca_act")
  source      IndicatorReadingSource @default(manual)
  recordedBy  String?                @map("recorded_by") @db.Uuid
  createdAt   DateTime               @default(now()) @map("created_at")
  updatedAt   DateTime               @updatedAt @map("updated_at")

  indicator Indicator @relation(fields: [indicatorId], references: [id], onDelete: Cascade)

  @@unique([indicatorId, periodYear, periodMonth])
  @@index([indicatorId])
  @@map("indicator_readings")
}

// ============================================================
// FEEDBACKS — Tela 6 (Fato → Impacto → Expectativa → Combinado → Prazo)
// ============================================================
model FeedbackRecord {
  id             String         @id @default(uuid()) @db.Uuid
  organizationId String         @map("organization_id") @db.Uuid
  authorId       String         @map("author_id") @db.Uuid
  subjectUserId  String?        @map("subject_user_id") @db.Uuid
  subjectLabel   String?        @map("subject_label") // livre quando não é usuário do sistema
  type           FeedbackType   @default(alinhamento)
  fact           String // Fato observável
  impact         String // Impacto no time/negócio
  expectation    String // O que se espera
  agreement      String? // O que ficou combinado
  dueAt          DateTime?      @map("due_at")
  followUpAt     DateTime?      @map("follow_up_at")
  status         FeedbackStatus @default(registrado)
  tags           String[]       @default([])
  createdAt      DateTime       @default(now()) @map("created_at")
  updatedAt      DateTime       @updatedAt @map("updated_at")

  @@index([organizationId])
  @@index([subjectUserId])
  @@index([status])
  @@map("feedback_records")
}

// ============================================================
// TEAM MEMBER PROFILE — Tela 3 (Mapa da Equipe)
// ============================================================
model TeamMemberProfile {
  id                   String        @id @default(uuid()) @db.Uuid
  organizationId       String        @map("organization_id") @db.Uuid
  membershipId         String        @unique @map("membership_id") @db.Uuid
  roleTitle            String?       @map("role_title")
  expectedDeliverables String[]      @default([]) @map("expected_deliverables")
  keyIndicators        String[]      @default([]) @map("key_indicators")
  autonomyLevel        AutonomyLevel @default(n2_acompanho) @map("autonomy_level")
  strengths            String[]      @default([])
  developPoints        String[]      @default([]) @map("develop_points")
  notes                String?
  performanceLevel     Int?          @map("performance_level")
  potentialLevel       Int?          @map("potential_level")
  discPrimary          String?       @map("disc_primary")
  updatedBy            String?       @map("updated_by") @db.Uuid
  createdAt            DateTime      @default(now()) @map("created_at")
  updatedAt            DateTime      @updatedAt @map("updated_at")

  @@index([organizationId])
  @@map("team_member_profiles")
}

// ============================================================
// PDIs — Planos de Desenvolvimento Individual
// ============================================================
model Pdi {
  id             String    @id @default(uuid()) @db.Uuid
  organizationId String    @map("organization_id") @db.Uuid
  subjectUserId  String    @map("subject_user_id") @db.Uuid
  authorId       String    @map("author_id") @db.Uuid
  title          String
  focus          String? // foco central (competência / módulo C.O.R.E.)
  startAt        DateTime  @default(now()) @map("start_at")
  reviewAt       DateTime? @map("review_at")
  status         PdiStatus @default(ativo)
  summary        String?
  createdAt      DateTime  @default(now()) @map("created_at")
  updatedAt      DateTime  @updatedAt @map("updated_at")

  goals PdiGoal[]

  @@index([organizationId, subjectUserId])
  @@index([status])
  @@map("pdis")
}

model PdiGoal {
  id        String        @id @default(uuid()) @db.Uuid
  pdiId     String        @map("pdi_id") @db.Uuid
  title     String
  action    String? // ação concreta
  dueAt     DateTime?     @map("due_at")
  status    PdiGoalStatus @default(a_fazer)
  evidence  String?
  createdAt DateTime      @default(now()) @map("created_at")
  updatedAt DateTime      @updatedAt @map("updated_at")

  pdi Pdi @relation(fields: [pdiId], references: [id], onDelete: Cascade)

  @@index([pdiId])
  @@map("pdi_goals")
}

// ============================================================
// 1:1s — Reuniões guiadas Líder ↔ Liderado
// Roteiro pré-definido + histórico + compromissos gerados
// ============================================================

enum OneOnOneStatus {
  scheduled
  in_progress
  done
  canceled
}

enum OneOnOneItemKind {
  wins
  challenges
  feedback
  development
  personal
  action
  note
}

model OneOnOne {
  id                  String         @id @default(uuid()) @db.Uuid
  organizationId      String         @map("organization_id") @db.Uuid
  leaderId            String         @map("leader_id") @db.Uuid
  subjectUserId       String         @map("subject_user_id") @db.Uuid
  scheduledAt         DateTime       @map("scheduled_at")
  durationMin         Int            @default(30) @map("duration_min")
  status              OneOnOneStatus @default(scheduled)
  mood                Int? // 1..5 humor do liderado (opcional)
  summary             String?
  privateNotes        String?        @map("private_notes")
  briefingMarkdown    String?        @map("briefing_markdown")
  briefingGeneratedAt DateTime?      @map("briefing_generated_at")
  createdAt           DateTime       @default(now()) @map("created_at")
  updatedAt           DateTime       @updatedAt @map("updated_at")

  items OneOnOneItem[]

  @@index([organizationId, subjectUserId])
  @@index([organizationId, scheduledAt])
  @@map("one_on_ones")
}

model OneOnOneItem {
  id         String           @id @default(uuid()) @db.Uuid
  oneOnOneId String           @map("one_on_one_id") @db.Uuid
  kind       OneOnOneItemKind
  content    String
  done       Boolean          @default(false)
  dueAt      DateTime?        @map("due_at")
  orderIndex Int              @default(0) @map("order_index")
  createdAt  DateTime         @default(now()) @map("created_at")
  updatedAt  DateTime         @updatedAt @map("updated_at")

  oneOnOne OneOnOne @relation(fields: [oneOnOneId], references: [id], onDelete: Cascade)

  @@index([oneOnOneId])
  @@map("one_on_one_items")
}

// ============================================================
// 360 leve — Rodada trimestral com 3 perguntas por avaliador
// ============================================================

enum ThreeSixtyStatus {
  open
  closed
}

model ThreeSixtyRound {
  id              String           @id @default(uuid()) @db.Uuid
  organizationId  String           @map("organization_id") @db.Uuid
  subjectUserId   String           @map("subject_user_id") @db.Uuid
  createdById     String           @map("created_by_id") @db.Uuid
  title           String
  quarter         String // ex.: "2026-Q1"
  status          ThreeSixtyStatus @default(open)
  summaryMarkdown String?          @map("summary_markdown")
  closedAt        DateTime?        @map("closed_at")
  createdAt       DateTime         @default(now()) @map("created_at")
  updatedAt       DateTime         @updatedAt @map("updated_at")

  responses ThreeSixtyResponse[]

  @@index([organizationId, subjectUserId])
  @@index([organizationId, status])
  @@map("three_sixty_rounds")
}

model ThreeSixtyResponse {
  id          String   @id @default(uuid()) @db.Uuid
  roundId     String   @map("round_id") @db.Uuid
  evaluatorId String   @map("evaluator_id") @db.Uuid
  score1      Int      @map("score_1") // Continuar fazendo (1..5)
  score2      Int      @map("score_2") // Começar a fazer (1..5)
  score3      Int      @map("score_3") // Parar de fazer (1..5)
  comment1    String?  @map("comment_1")
  comment2    String?  @map("comment_2")
  comment3    String?  @map("comment_3")
  createdAt   DateTime @default(now()) @map("created_at")
  updatedAt   DateTime @updatedAt @map("updated_at")

  round ThreeSixtyRound @relation(fields: [roundId], references: [id], onDelete: Cascade)

  @@unique([roundId, evaluatorId])
  @@index([roundId])
  @@map("three_sixty_responses")
}

// ============================================================
// Pulsos — links públicos com token para o liderado responder
// (feedback solicitado, pulse de clima, DISC leve, pesquisa custom)
// ============================================================

enum PulseKind {
  feedback
  climate
  disc
  custom
}

enum PulseSendStatus {
  pending
  answered
  expired
  revoked
}

model PulseTemplate {
  id             String    @id @default(uuid()) @db.Uuid
  organizationId String?   @map("organization_id") @db.Uuid
  kind           PulseKind
  title          String
  intro          String?
  // schema of questions: [{ id, label, type: 'scale'|'text'|'choice'|'disc_pair', options?, required? }]
  questions      Json
  isSystem       Boolean   @default(false) @map("is_system")
  createdById    String?   @map("created_by_id") @db.Uuid
  createdAt      DateTime  @default(now()) @map("created_at")
  updatedAt      DateTime  @updatedAt @map("updated_at")

  sends PulseSend[]

  @@index([organizationId, kind])
  @@map("pulse_templates")
}

model PulseSend {
  id             String          @id @default(uuid()) @db.Uuid
  organizationId String          @map("organization_id") @db.Uuid
  templateId     String          @map("template_id") @db.Uuid
  senderId       String          @map("sender_id") @db.Uuid
  subjectUserId  String?         @map("subject_user_id") @db.Uuid
  subjectLabel   String?         @map("subject_label")
  subjectPhone   String?         @map("subject_phone")
  token          String          @unique
  message        String? // custom message shown on the public page
  status         PulseSendStatus @default(pending)
  expiresAt      DateTime        @map("expires_at")
  answeredAt     DateTime?       @map("answered_at")
  createdAt      DateTime        @default(now()) @map("created_at")
  updatedAt      DateTime        @updatedAt @map("updated_at")

  template PulseTemplate @relation(fields: [templateId], references: [id], onDelete: Cascade)
  answer   PulseAnswer?

  @@index([organizationId, status])
  @@index([subjectUserId])
  @@map("pulse_sends")
}

model PulseAnswer {
  id           String   @id @default(uuid()) @db.Uuid
  sendId       String   @unique @map("send_id") @db.Uuid
  // answers: { [questionId]: value }  where value is number|string|string[]
  answers      Json
  // aiSummary: short text summarizing the answer set (auto-generated)
  aiSummary    String?  @map("ai_summary")
  // discProfile: { D, I, S, C } scores when kind=disc
  discProfile  Json?    @map("disc_profile")
  respondentIp String?  @map("respondent_ip")
  userAgent    String?  @map("user_agent")
  createdAt    DateTime @default(now()) @map("created_at")

  send PulseSend @relation(fields: [sendId], references: [id], onDelete: Cascade)

  @@map("pulse_answers")
}

// ============================================================
// Ciclos com metas SMART (Fase 1 · item 5)
// Um ciclo é um horizonte (trimestre, semestre) com metas ligadas a indicadores.
// ============================================================
enum CycleStatus {
  planning
  active
  closed
}

enum CycleGoalStatus {
  on_track
  at_risk
  off_track
  done
  dropped
}

model Cycle {
  id             String      @id @default(uuid()) @db.Uuid
  organizationId String      @map("organization_id") @db.Uuid
  name           String
  startAt        DateTime    @map("start_at")
  endAt          DateTime    @map("end_at")
  status         CycleStatus @default(planning)
  summary        String?
  createdBy      String?     @map("created_by") @db.Uuid
  createdAt      DateTime    @default(now()) @map("created_at")
  updatedAt      DateTime    @updatedAt @map("updated_at")

  goals CycleGoal[]

  @@index([organizationId, status])
  @@map("cycles")
}

model CycleGoal {
  id           String          @id @default(uuid()) @db.Uuid
  cycleId      String          @map("cycle_id") @db.Uuid
  title        String
  specific     String?
  measurable   String?
  achievable   String?
  relevant     String?
  timeBound    String?         @map("time_bound")
  ownerUserId  String?         @map("owner_user_id") @db.Uuid
  areaId       String?         @map("area_id") @db.Uuid
  indicatorId  String?         @map("indicator_id") @db.Uuid
  targetValue  Float?          @map("target_value")
  status       CycleGoalStatus @default(on_track)
  createdAt    DateTime        @default(now()) @map("created_at")
  updatedAt    DateTime        @updatedAt @map("updated_at")

  cycle Cycle @relation(fields: [cycleId], references: [id], onDelete: Cascade)

  @@index([cycleId])
  @@index([indicatorId])
  @@map("cycle_goals")
}

// ============================================================
// KUDOS — Reconhecimento entre pares
// ============================================================
enum KudosCategory {
  resultado
  atitude
  colaboracao
  aprendizado
  inovacao
  outro
}

model Kudos {
  id             String        @id @default(uuid()) @db.Uuid
  organizationId String        @map("organization_id") @db.Uuid
  authorId       String        @map("author_id") @db.Uuid
  subjectUserId  String?       @map("subject_user_id") @db.Uuid
  subjectLabel   String?       @map("subject_label")
  category       KudosCategory @default(atitude)
  message        String
  tags           String[]      @default([])
  createdAt      DateTime      @default(now()) @map("created_at")

  @@index([organizationId, createdAt])
  @@index([subjectUserId])
  @@map("kudos")
}

// ============================================================
// Retrospectiva de ciclo (Fase 2 · item 4)
// Wizard de fechamento: o que funcionou, o que melhorar,
// aprendizados, próximos passos e nota de confiança do ciclo.
// ============================================================
model CycleRetrospective {
  id             String   @id @default(uuid()) @db.Uuid
  cycleId        String   @map("cycle_id") @db.Uuid
  organizationId String   @map("organization_id") @db.Uuid
  areaId         String?  @map("area_id") @db.Uuid
  wentWell       String?  @map("went_well")
  toImprove      String?  @map("to_improve")
  learnings      String?
  nextSteps      String?  @map("next_steps")
  confidence     Int?
  createdBy      String?  @map("created_by") @db.Uuid
  createdAt      DateTime @default(now()) @map("created_at")
  updatedAt      DateTime @updatedAt @map("updated_at")

  @@index([cycleId])
  @@index([organizationId, createdAt])
  @@map("cycle_retrospectives")
}
