// Prisma schema for LÍDER C.O.R.E.
// Self-hosted Postgres model for the EasyPanel deployment.

generator client {
  provider = "prisma-client-js"
  output   = "../api/node_modules/.prisma/client"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum AppRole {
  super_admin
  neo_admin
  franchise_owner
  hr_admin
  leader
  collaborator
}

enum PlanTier {
  essencial
  profissional
  enterprise
}

enum OrgStatus {
  trial
  active
  suspended
  canceled
}

enum FranchiseRole {
  owner
  admin
  consultant
}

enum FranchiseStatus {
  trial
  active
  suspended
  canceled
}

enum SubscriptionOwnerType {
  franchise
  organization
}

enum SubscriptionStatus {
  trial
  active
  past_due
  canceled
}

enum InvoiceStatus {
  draft
  open
  paid
  void
  uncollectible
}

enum AIProvider {
  openai
  gemini
}

enum ScopeType {
  global
  franchise
  organization
}

enum Platform {
  web
  desktop
  mobile
}

enum ReleaseChannel {
  stable
  beta
}

enum LicenseStatus {
  active
  suspended
  canceled
  expired
}

enum PermissionAction {
  view
  edit
  delete
  export
  admin
}

enum OnboardingItemKey {
  company_created
  users_imported
  leaders_defined
  teams_created
  areas_created
  rituals_configured
  assessments_setup
  ai_configured
  training_completed
}

enum ModuleCategory {
  core
  ia
  analytics
  people
  integrations
}

model User {
  id           String   @id @default(uuid()) @db.Uuid
  email        String   @unique
  passwordHash String   @map("password_hash")
  createdAt    DateTime @default(now()) @map("created_at")
  updatedAt    DateTime @updatedAt @map("updated_at")

  profile              Profile?
  roles                UserRole[]
  memberships          Membership[]
  franchiseMemberships FranchiseMember[]
  ownedFranchises      Franchise[]       @relation("FranchiseOwner")
  auditLogs            AuditLog[]

  @@map("users")
}

model Profile {
  id        String   @id @db.Uuid
  user      User     @relation(fields: [id], references: [id], onDelete: Cascade)
  fullName  String?  @map("full_name")
  avatarUrl String?  @map("avatar_url")
  jobTitle  String?  @map("job_title")
  phone     String?
  cpf       String?
  whatsapp  String?
  mfaEnabled Boolean @default(false) @map("mfa_enabled")
  lastLoginAt DateTime? @map("last_login_at")
  status    String   @default("active")
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  @@map("profiles")
}

model UserRole {
  id     String  @id @default(uuid()) @db.Uuid
  userId String  @map("user_id") @db.Uuid
  role   AppRole
  user   User    @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, role])
  @@map("user_roles")
}

model Organization {
  id          String    @id @default(uuid()) @db.Uuid
  name        String
  slug        String    @unique
  cnpj        String?
  legalName   String?   @map("legal_name")
  tradeName   String?   @map("trade_name")
  stateRegistration String? @map("state_registration")
  segment     String?
  address     String?
  city        String?
  state       String?
  zipCode     String?   @map("zip_code")
  country     String?   @default("BR")
  phone       String?
  whatsapp    String?
  email       String?
  website     String?
  logoUrl     String?   @map("logo_url")
  primaryColor String?  @map("primary_color")
  employeeCount Int?    @map("employee_count")
  leaderCount   Int?    @map("leader_count")
  licenseCount  Int?    @map("license_count")
  notes         String?
  plan        PlanTier  @default(essencial)
  status      OrgStatus @default(trial)
  franchiseId String?   @map("franchise_id") @db.Uuid
  createdAt   DateTime  @default(now()) @map("created_at")
  updatedAt   DateTime  @updatedAt @map("updated_at")

  memberships Membership[]
  franchise   Franchise?   @relation(fields: [franchiseId], references: [id], onDelete: SetNull)
  branches    Branch[]
  areas       Area[]
  teams       Team[]
  licenses    License[]
  onboardingItems OnboardingItem[]

  orgRoles           OrgRole[]
  rituals            Ritual[]
  delegations        Delegation[]
  decisions          Decision[]
  documents          OrgDocument[]
  healthSnapshots    HealthScoreSnapshot[]

  @@map("organizations")
}

model Membership {
  id             String   @id @default(uuid()) @db.Uuid
  userId         String   @map("user_id") @db.Uuid
  organizationId String   @map("organization_id") @db.Uuid
  role           AppRole  @default(collaborator)
  branchId       String?  @map("branch_id") @db.Uuid
  areaId         String?  @map("area_id") @db.Uuid
  teamId         String?  @map("team_id") @db.Uuid
  directLeaderId String?  @map("direct_leader_id") @db.Uuid
  createdAt      DateTime @default(now()) @map("created_at")

  user         User         @relation(fields: [userId], references: [id], onDelete: Cascade)
  organization Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  branch       Branch?      @relation(fields: [branchId], references: [id], onDelete: SetNull)
  area         Area?        @relation(fields: [areaId], references: [id], onDelete: SetNull)
  team         Team?        @relation(fields: [teamId], references: [id], onDelete: SetNull)

  ritualParticipations RitualParticipant[]
  roleAssignments      RoleAssignment[]

  @@unique([userId, organizationId])
  @@map("memberships")
}

model Branch {
  id             String   @id @default(uuid()) @db.Uuid
  organizationId String   @map("organization_id") @db.Uuid
  name           String
  code           String?
  address        String?
  city           String?
  state          String?
  zipCode        String?  @map("zip_code")
  phone          String?
  responsibleUserId String? @map("responsible_user_id") @db.Uuid
  active         Boolean  @default(true)
  createdAt      DateTime @default(now()) @map("created_at")
  updatedAt      DateTime @updatedAt @map("updated_at")

  organization Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  areas        Area[]
  memberships  Membership[]

  @@unique([organizationId, code])
  @@index([organizationId])
  @@map("branches")
}

model Area {
  id             String   @id @default(uuid()) @db.Uuid
  organizationId String   @map("organization_id") @db.Uuid
  branchId       String?  @map("branch_id") @db.Uuid
  name           String
  description    String?
  managerUserId  String?  @map("manager_user_id") @db.Uuid
  active         Boolean  @default(true)
  mission        String?
  objective      String?
  kpis           String[] @default([])
  contextMd      String?  @map("context_md")
  tags           String[] @default([])
  createdAt      DateTime @default(now()) @map("created_at")
  updatedAt      DateTime @updatedAt @map("updated_at")

  organization Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  branch       Branch?      @relation(fields: [branchId], references: [id], onDelete: SetNull)
  teams        Team[]
  memberships  Membership[]

  @@index([organizationId])
  @@map("areas")
}

model Team {
  id             String   @id @default(uuid()) @db.Uuid
  organizationId String   @map("organization_id") @db.Uuid
  areaId         String   @map("area_id") @db.Uuid
  name           String
  objectives     String?
  responsibleUserId String? @map("responsible_user_id") @db.Uuid
  active         Boolean  @default(true)
  mission        String?
  kpis           String[] @default([])
  leaderMembershipId String? @map("leader_membership_id") @db.Uuid
  contextMd      String?  @map("context_md")
  tags           String[] @default([])
  createdAt      DateTime @default(now()) @map("created_at")
  updatedAt      DateTime @updatedAt @map("updated_at")

  organization Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  area         Area         @relation(fields: [areaId], references: [id], onDelete: Cascade)
  memberships  Membership[]

  @@index([areaId])
  @@map("teams")
}

model ProductModule {
  id          String         @id @default(uuid()) @db.Uuid
  code        String         @unique
  name        String
  description String?
  category    ModuleCategory @default(core)
  orderIndex  Int            @default(0) @map("order_index")
  active      Boolean        @default(true)
  createdAt   DateTime       @default(now()) @map("created_at")
  updatedAt   DateTime       @updatedAt @map("updated_at")

  planModules PlanModule[]

  @@map("product_modules")
}

model PlanModule {
  id        String   @id @default(uuid()) @db.Uuid
  planId    String   @map("plan_id") @db.Uuid
  moduleId  String   @map("module_id") @db.Uuid
  createdAt DateTime @default(now()) @map("created_at")

  plan   Plan          @relation(fields: [planId], references: [id], onDelete: Cascade)
  module ProductModule @relation(fields: [moduleId], references: [id], onDelete: Cascade)

  @@unique([planId, moduleId])
  @@map("plan_modules")
}

model RolePermission {
  id        String           @id @default(uuid()) @db.Uuid
  role      AppRole
  resource  String
  action    PermissionAction
  createdAt DateTime         @default(now()) @map("created_at")

  @@unique([role, resource, action])
  @@index([role])
  @@map("role_permissions")
}

model License {
  id             String        @id @default(uuid()) @db.Uuid
  organizationId String        @map("organization_id") @db.Uuid
  planId         String        @map("plan_id") @db.Uuid
  seats          Int           @default(1)
  status         LicenseStatus @default(active)
  activatedAt    DateTime?     @map("activated_at")
  renewsAt       DateTime?     @map("renews_at")
  expiresAt      DateTime?     @map("expires_at")
  notes          String?
  createdAt      DateTime      @default(now()) @map("created_at")
  updatedAt      DateTime      @updatedAt @map("updated_at")

  organization Organization       @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  plan         Plan               @relation(fields: [planId], references: [id])
  assignments  LicenseAssignment[]

  @@index([organizationId])
  @@map("licenses")
}

model LicenseAssignment {
  id         String    @id @default(uuid()) @db.Uuid
  licenseId  String    @map("license_id") @db.Uuid
  userId     String    @map("user_id") @db.Uuid
  assignedAt DateTime  @default(now()) @map("assigned_at")
  revokedAt  DateTime? @map("revoked_at")

  license License @relation(fields: [licenseId], references: [id], onDelete: Cascade)

  @@unique([licenseId, userId])
  @@map("license_assignments")
}

model OnboardingItem {
  id             String            @id @default(uuid()) @db.Uuid
  organizationId String            @map("organization_id") @db.Uuid
  key            OnboardingItemKey
  completed      Boolean           @default(false)
  completedAt    DateTime?         @map("completed_at")
  notes          String?
  createdAt      DateTime          @default(now()) @map("created_at")
  updatedAt      DateTime          @updatedAt @map("updated_at")

  organization Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)

  @@unique([organizationId, key])
  @@map("onboarding_items")
}

model Franchise {
  id          String          @id @default(uuid()) @db.Uuid
  name        String
  slug        String          @unique
  cnpj        String?
  ownerUserId String?         @map("owner_user_id") @db.Uuid
  planId      String?         @map("plan_id") @db.Uuid
  status      FranchiseStatus @default(trial)
  branding    Json?
  createdAt   DateTime        @default(now()) @map("created_at")
  updatedAt   DateTime        @updatedAt @map("updated_at")

  owner         User?             @relation("FranchiseOwner", fields: [ownerUserId], references: [id], onDelete: SetNull)
  plan          Plan?             @relation(fields: [planId], references: [id], onDelete: SetNull)
  members       FranchiseMember[]
  organizations Organization[]

  @@map("franchises")
}

model FranchiseMember {
  id          String        @id @default(uuid()) @db.Uuid
  franchiseId String        @map("franchise_id") @db.Uuid
  userId      String        @map("user_id") @db.Uuid
  role        FranchiseRole @default(consultant)
  createdAt   DateTime      @default(now()) @map("created_at")

  franchise Franchise @relation(fields: [franchiseId], references: [id], onDelete: Cascade)
  user      User      @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([franchiseId, userId])
  @@map("franchise_members")
}

model Plan {
  id           String   @id @default(uuid()) @db.Uuid
  name         String
  slug         String   @unique
  description  String?
  priceMonthly Int      @default(0) @map("price_monthly")
  priceYearly  Int      @default(0) @map("price_yearly")
  currency     String   @default("BRL")
  limits       Json?
  features     String[] @default([])
  active       Boolean  @default(true)
  createdAt    DateTime @default(now()) @map("created_at")
  updatedAt    DateTime @updatedAt @map("updated_at")

  franchises    Franchise[]
  subscriptions Subscription[]
  planModules   PlanModule[]
  licenses      License[]

  @@map("plans")
}

model Subscription {
  id                     String                @id @default(uuid()) @db.Uuid
  ownerType              SubscriptionOwnerType @map("owner_type")
  ownerId                String                @map("owner_id") @db.Uuid
  planId                 String                @map("plan_id") @db.Uuid
  status                 SubscriptionStatus    @default(trial)
  currentPeriodStart     DateTime?             @map("current_period_start")
  currentPeriodEnd       DateTime?             @map("current_period_end")
  cancelAt               DateTime?             @map("cancel_at")
  provider               String? // stripe | manual
  providerCustomerId     String?               @map("provider_customer_id")
  providerSubscriptionId String?               @map("provider_subscription_id")
  createdAt              DateTime              @default(now()) @map("created_at")
  updatedAt              DateTime              @updatedAt @map("updated_at")

  plan     Plan      @relation(fields: [planId], references: [id])
  invoices Invoice[]

  @@index([ownerType, ownerId])
  @@map("subscriptions")
}

model Invoice {
  id                String        @id @default(uuid()) @db.Uuid
  subscriptionId    String        @map("subscription_id") @db.Uuid
  amountCents       Int           @map("amount_cents")
  currency          String        @default("BRL")
  status            InvoiceStatus @default(open)
  dueDate           DateTime?     @map("due_date")
  paidAt            DateTime?     @map("paid_at")
  providerInvoiceId String?       @map("provider_invoice_id")
  pdfUrl            String?       @map("pdf_url")
  createdAt         DateTime      @default(now()) @map("created_at")

  subscription Subscription @relation(fields: [subscriptionId], references: [id], onDelete: Cascade)

  @@map("invoices")
}

model AISettings {
  id                String     @id @default(uuid()) @db.Uuid
  scope             ScopeType
  scopeId           String?    @map("scope_id") @db.Uuid
  provider          AIProvider
  model             String
  apiKeySecretRef   String?    @map("api_key_secret_ref")
  monthlyTokenLimit Int?       @map("monthly_token_limit")
  temperature       Float      @default(0.7)
  createdAt         DateTime   @default(now()) @map("created_at")
  updatedAt         DateTime   @updatedAt @map("updated_at")

  @@unique([scope, scopeId])
  @@map("ai_settings")
}

model AIUsage {
  id               String     @id @default(uuid()) @db.Uuid
  organizationId   String?    @map("organization_id") @db.Uuid
  franchiseId      String?    @map("franchise_id") @db.Uuid
  userId           String?    @map("user_id") @db.Uuid
  provider         AIProvider
  model            String
  promptTokens     Int        @default(0) @map("prompt_tokens")
  completionTokens Int        @default(0) @map("completion_tokens")
  costCents        Int        @default(0) @map("cost_cents")
  createdAt        DateTime   @default(now()) @map("created_at")

  @@index([organizationId])
  @@index([franchiseId])
  @@index([userId])
  @@map("ai_usage")
}

model Branding {
  id            String    @id @default(uuid()) @db.Uuid
  scope         ScopeType
  scopeId       String?   @map("scope_id") @db.Uuid
  logoUrl       String?   @map("logo_url")
  primaryColor  String?   @map("primary_color")
  accentColor   String?   @map("accent_color")
  faviconUrl    String?   @map("favicon_url")
  emailFromName String?   @map("email_from_name")
  createdAt     DateTime  @default(now()) @map("created_at")
  updatedAt     DateTime  @updatedAt @map("updated_at")

  @@unique([scope, scopeId])
  @@map("branding")
}

model MethodologyCompetency {
  id          String   @id @default(uuid()) @db.Uuid
  code        String   @unique
  name        String
  description String?
  weight      Int      @default(1)
  orderIndex  Int      @default(0) @map("order_index")
  active      Boolean  @default(true)
  createdAt   DateTime @default(now()) @map("created_at")
  updatedAt   DateTime @updatedAt @map("updated_at")

  @@map("methodology_competencies")
}

model AppRelease {
  id           String         @id @default(uuid()) @db.Uuid
  platform     Platform
  version      String
  channel      ReleaseChannel @default(stable)
  releaseNotes String?        @map("release_notes")
  downloadUrl  String?        @map("download_url")
  publishedAt  DateTime       @default(now()) @map("published_at")

  @@unique([platform, version, channel])
  @@map("apps_releases")
}

model AuditLog {
  id          String   @id @default(uuid()) @db.Uuid
  actorUserId String?  @map("actor_user_id") @db.Uuid
  action      String
  targetType  String?  @map("target_type")
  targetId    String?  @map("target_id")
  metadata    Json?
  createdAt   DateTime @default(now()) @map("created_at")

  actor User? @relation(fields: [actorUserId], references: [id], onDelete: SetNull)

  @@index([actorUserId])
  @@index([targetType, targetId])
  @@map("audit_log")
}

enum SettingCategory {
  general
  smtp
  whatsapp
  sso
  backup
  billing
  security
  integrations
  notifications
}

model PlatformSetting {
  id         String          @id @default(uuid()) @db.Uuid
  scope      ScopeType       @default(global)
  scopeId    String?         @map("scope_id") @db.Uuid
  category   SettingCategory @default(general)
  key        String
  value      String?
  secret     Boolean         @default(false)
  updatedBy  String?         @map("updated_by") @db.Uuid
  createdAt  DateTime        @default(now()) @map("created_at")
  updatedAt  DateTime        @updatedAt @map("updated_at")

  @@unique([scope, scopeId, category, key])
  @@index([category])
  @@map("platform_settings")
}

enum NotificationChannel {
  whatsapp_uazapi
  whatsapp_meta
  email
  sms
  in_app
}

enum NotificationStatus {
  pending
  sent
  delivered
  read
  failed
}

enum NotificationDirection {
  outbound
  inbound
}

model NotificationTemplate {
  id          String              @id @default(uuid()) @db.Uuid
  code        String              @unique
  name        String
  channel     NotificationChannel
  subject     String?
  body        String
  // Meta Cloud API approved template name (homologação). Se preenchido,
  // usa `template` em vez de `text` no envio via canal Meta.
  metaTemplateName String?         @map("meta_template_name")
  metaLanguage     String?         @default("pt_BR") @map("meta_language")
  variables   Json?
  active      Boolean             @default(true)
  createdAt   DateTime            @default(now()) @map("created_at")
  updatedAt   DateTime            @updatedAt @map("updated_at")

  @@index([channel])
  @@map("notification_templates")
}

model NotificationLog {
  id           String                @id @default(uuid()) @db.Uuid
  channel      NotificationChannel
  direction    NotificationDirection @default(outbound)
  status       NotificationStatus    @default(pending)
  to           String
  from         String?
  templateCode String?               @map("template_code")
  subject      String?
  body         String?
  providerId   String?               @map("provider_id")
  providerRaw  Json?                 @map("provider_raw")
  error        String?
  userId       String?               @map("user_id") @db.Uuid
  organizationId String?             @map("organization_id") @db.Uuid
  createdAt    DateTime              @default(now()) @map("created_at")
  updatedAt    DateTime              @updatedAt @map("updated_at")

  @@index([channel])
  @@index([status])
  @@index([createdAt])
  @@index([to])
  @@map("notification_logs")
}

// ============================================================
// MÓDULO ORGANIZAÇÃO — base operacional da liderança.
// Toda entidade traz auditoria + campos preparados para IA
// (contextMd, tags, history) para o Coach usar depois.
// ============================================================

enum RitualType {
  daily
  weekly
  one_on_one
  feedback
  action_plan
  indicators
  strategic
  day_one
  checkpoint
  retro
  custom
}

enum RitualScope {
  org
  branch
  area
  team
}

enum RitualStatus {
  active
  paused
  archived
}

enum RitualOccurrenceStatus {
  scheduled
  in_progress
  done
  missed
  canceled
}

enum DelegationStatus {
  open
  in_progress
  blocked
  done
  canceled
}

enum DelegationPriority {
  low
  medium
  high
  critical
}

enum DecisionStatus {
  open
  in_progress
  done
  reverted
}

enum DocumentKind {
  policy
  procedure
  flow
  material
  video
  pdf
  link
  other
}

model OrgRole {
  id               String   @id @default(uuid()) @db.Uuid
  organizationId   String   @map("organization_id") @db.Uuid
  title            String
  mission          String?
  responsibilities String[] @default([])
  deliverables     String[] @default([])
  competencies     String[] @default([])
  relationships    String[] @default([])
  isLeader         Boolean  @default(false) @map("is_leader")
  contextMd        String?  @map("context_md")
  tags             String[] @default([])
  createdBy        String?  @map("created_by") @db.Uuid
  updatedBy        String?  @map("updated_by") @db.Uuid
  createdAt        DateTime @default(now()) @map("created_at")
  updatedAt        DateTime @updatedAt @map("updated_at")

  organization Organization    @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  assignments  RoleAssignment[]

  @@index([organizationId])
  @@map("org_roles")
}

model RoleAssignment {
  id           String   @id @default(uuid()) @db.Uuid
  roleId       String   @map("role_id") @db.Uuid
  membershipId String   @map("membership_id") @db.Uuid
  createdAt    DateTime @default(now()) @map("created_at")

  role       OrgRole    @relation(fields: [roleId], references: [id], onDelete: Cascade)
  membership Membership @relation(fields: [membershipId], references: [id], onDelete: Cascade)

  @@unique([roleId, membershipId])
  @@map("role_assignments")
}

model Ritual {
  id             String       @id @default(uuid()) @db.Uuid
  organizationId String       @map("organization_id") @db.Uuid
  scope          RitualScope  @default(team)
  scopeId        String?      @map("scope_id") @db.Uuid
  name           String
  type           RitualType   @default(custom)
  objective      String?
  cadence        String?
  ownerId        String?      @map("owner_id") @db.Uuid
  durationMin    Int          @default(30) @map("duration_min")
  agendaTemplate String?      @map("agenda_template")
  checklist      Json?
  status         RitualStatus @default(active)
  tags           String[]     @default([])
  contextMd      String?      @map("context_md")
  createdBy      String?      @map("created_by") @db.Uuid
  updatedBy      String?      @map("updated_by") @db.Uuid
  createdAt      DateTime     @default(now()) @map("created_at")
  updatedAt      DateTime     @updatedAt @map("updated_at")

  organization Organization        @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  participants RitualParticipant[]
  occurrences  RitualOccurrence[]

  @@index([organizationId])
  @@index([scope, scopeId])
  @@map("rituals")
}

model RitualParticipant {
  id           String   @id @default(uuid()) @db.Uuid
  ritualId     String   @map("ritual_id") @db.Uuid
  membershipId String   @map("membership_id") @db.Uuid
  role         String   @default("required")
  createdAt    DateTime @default(now()) @map("created_at")

  ritual     Ritual     @relation(fields: [ritualId], references: [id], onDelete: Cascade)
  membership Membership @relation(fields: [membershipId], references: [id], onDelete: Cascade)

  @@unique([ritualId, membershipId])
  @@map("ritual_participants")
}

model RitualOccurrence {
  id          String                 @id @default(uuid()) @db.Uuid
  ritualId    String                 @map("ritual_id") @db.Uuid
  scheduledAt DateTime               @map("scheduled_at")
  startedAt   DateTime?              @map("started_at")
  endedAt     DateTime?              @map("ended_at")
  status      RitualOccurrenceStatus @default(scheduled)
  minutes     String?
  aiSummary   String?                @map("ai_summary")
  notes       String?
  pendings    Json?
  createdAt   DateTime               @default(now()) @map("created_at")
  updatedAt   DateTime               @updatedAt @map("updated_at")

  ritual    Ritual     @relation(fields: [ritualId], references: [id], onDelete: Cascade)
  decisions Decision[]

  @@index([ritualId])
  @@index([scheduledAt])
  @@map("ritual_occurrences")
}

model Delegation {
  id             String             @id @default(uuid()) @db.Uuid
  organizationId String             @map("organization_id") @db.Uuid
  areaId         String?            @map("area_id") @db.Uuid
  teamId         String?            @map("team_id") @db.Uuid
  title          String
  description    String?
  assigneeId     String?            @map("assignee_id") @db.Uuid
  delegatorId    String?            @map("delegator_id") @db.Uuid
  dueAt          DateTime?          @map("due_at")
  priority       DelegationPriority @default(medium)
  doneCriteria   String?            @map("done_criteria")
  doneAt         DateTime?          @map("done_at")
  status         DelegationStatus   @default(open)
  tags           String[]           @default([])
  contextMd      String?            @map("context_md")
  attachments    Json?
  history        Json?
  createdBy      String?            @map("created_by") @db.Uuid
  updatedBy      String?            @map("updated_by") @db.Uuid
  createdAt      DateTime           @default(now()) @map("created_at")
  updatedAt      DateTime           @updatedAt @map("updated_at")

  organization Organization        @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  comments     DelegationComment[]

  @@index([organizationId])
  @@index([status])
  @@index([dueAt])
  @@map("delegations")
}

model DelegationComment {
  id           String   @id @default(uuid()) @db.Uuid
  delegationId String   @map("delegation_id") @db.Uuid
  authorId     String?  @map("author_id") @db.Uuid
  body         String
  createdAt    DateTime @default(now()) @map("created_at")

  delegation Delegation @relation(fields: [delegationId], references: [id], onDelete: Cascade)

  @@index([delegationId])
  @@map("delegation_comments")
}

model Decision {
  id                 String         @id @default(uuid()) @db.Uuid
  organizationId     String         @map("organization_id") @db.Uuid
  ritualOccurrenceId String?        @map("ritual_occurrence_id") @db.Uuid
  title              String
  context            String?
  decision           String
  ownerId            String?        @map("owner_id") @db.Uuid
  dueAt              DateTime?      @map("due_at")
  expectedResult     String?        @map("expected_result")
  status             DecisionStatus @default(open)
  tags               String[]       @default([])
  history            Json?
  createdBy          String?        @map("created_by") @db.Uuid
  updatedBy          String?        @map("updated_by") @db.Uuid
  createdAt          DateTime       @default(now()) @map("created_at")
  updatedAt          DateTime       @updatedAt @map("updated_at")

  organization     Organization      @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  ritualOccurrence RitualOccurrence? @relation(fields: [ritualOccurrenceId], references: [id], onDelete: SetNull)

  @@index([organizationId])
  @@index([status])
  @@map("decisions")
}

model OrgDocument {
  id             String       @id @default(uuid()) @db.Uuid
  organizationId String       @map("organization_id") @db.Uuid
  scope          RitualScope  @default(area)
  scopeId        String?      @map("scope_id") @db.Uuid
  title          String
  kind           DocumentKind @default(other)
  url            String?
  mime           String?
  size           Int?
  tags           String[]     @default([])
  description    String?
  uploadedBy     String?      @map("uploaded_by") @db.Uuid
  createdAt      DateTime     @default(now()) @map("created_at")
  updatedAt      DateTime     @updatedAt @map("updated_at")

  organization Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)

  @@index([organizationId])
  @@index([scope, scopeId])
  @@map("org_documents")
}

model HealthScoreSnapshot {
  id             String   @id @default(uuid()) @db.Uuid
  organizationId String   @map("organization_id") @db.Uuid
  areaId         String?  @map("area_id") @db.Uuid
  teamId         String?  @map("team_id") @db.Uuid
  score          Int
  breakdown      Json
  computedAt     DateTime @default(now()) @map("computed_at")

  organization Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)

  @@index([organizationId, computedAt])
  @@index([areaId])
  @@index([teamId])
  @@map("health_score_snapshots")
}
