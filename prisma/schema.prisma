// ============================================================
// MÓDULO E — Evolução (score de sustentação por líder)
// ============================================================
model LeadershipScoreSnapshot {
  id              String   @id @default(uuid()) @db.Uuid
  organizationId  String   @map("organization_id") @db.Uuid
  userId          String   @map("user_id") @db.Uuid
  periodYear      Int      @map("period_year")
  periodMonth     Int      @map("period_month")
  score           Int
  ritualsScore    Float    @map("rituals_score")
  delegScore      Float    @map("deleg_score")
  indicatorsScore Float    @map("indicators_score")
  diagnostic      String?
  breakdown       Json?
  hardScore       Int      @default(0) @map("hard_score")
  softScore       Int      @default(0) @map("soft_score")
  heartScore      Int      @default(0) @map("heart_score")
