POSTGRES_USER=postgres
POSTGRES_PASSWORD=change-me
POSTGRES_DB=lidercore

JWT_SECRET=change-me-generate-a-long-random-string
JWT_EXPIRES_IN=7d

# Public URL where the API will be reachable from the browser.
# In EasyPanel, set this to https://api.yourdomain.com
VITE_API_URL=http://localhost:4000

# Allowed CORS origins (comma-separated) for the API. Use * only for local dev.
CORS_ORIGIN=http://localhost:3000

